# BuildFrog — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# -------------------------------------------------------
# UI Access
# -------------------------------------------------------
WORKSHOP_PASSWORD=your_secure_password_here

# -------------------------------------------------------
# Bambu Lab Printer (LAN Mode)
# Find these under Settings → Network on your printer
# -------------------------------------------------------
BAMBU_PRINTER_IP=192.168.1.xxx
BAMBU_PRINTER_SERIAL=your_printer_serial_here
BAMBU_PRINTER_ACCESS_CODE=your_8digit_access_code

# -------------------------------------------------------
# Local AI (Ollama) — optional but recommended for privacy
# -------------------------------------------------------
OLLAMA_URL=http://localhost:11434

# -------------------------------------------------------
# Commercial LLM APIs — all optional
# -------------------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# -------------------------------------------------------
# Storage (Docker volume path on host)
# -------------------------------------------------------
HOST_MODELS_DIR=./models
